<!--
  Immersive AI chat window (Milestone 2): those near you on the left, the shared story on the
  right - deep-memory overview up top, the recorded turns as a thread, and a line to simply write
  first. Uses only Native/SandBox brushes and sprites so it needs no assets of its own.
  Loaded by ChatWindowManager via GauntletLayer.LoadMovie("ImmersiveChatWindow", ChatWindowVM).
-->
<Prefab>
  <Window>
    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent">
      <Children>

        <!-- Dim the world behind, softly -->
        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Sprite="BlankWhiteSquare_9" Color="#000000FF" AlphaFactor="0.40" />

        <!-- The window itself -->
        <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="1160" SuggestedHeight="740" HorizontalAlignment="Center" VerticalAlignment="Center">
          <Children>

            <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Sprite="BlankWhiteSquare_9" Color="#14100BFF" AlphaFactor="0.97" />

            <!-- ============================ left: those near you ============================ -->
            <Widget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="330" HorizontalAlignment="Left" MarginLeft="20" MarginTop="18" MarginBottom="18">
              <Children>

                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="40" VerticalAlignment="Top" Brush="Popup.Title.Text" Brush.TextHorizontalAlignment="Left" Text="@TitleText" />

                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" MarginTop="52">
                  <Children>

                    <ScrollablePanel Id="ContactsScroller" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" ClipRect="ContactsClip" InnerPanel="ContactsClip\ContactsList" VerticalScrollbar="..\ContactsScrollbar" MouseScrollAxis="Vertical" AutoHideScrollBars="true">
                      <Children>
                        <Widget Id="ContactsClip" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" ClipContents="true">
                          <Children>
                            <ListPanel Id="ContactsList" DataSource="{Contacts}" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Top" StackLayout.LayoutMethod="VerticalTopToBottom">
                              <ItemTemplate>
                                <ButtonWidget DoNotPassEventsToChildren="true" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="68" Command.Click="ExecuteSelect">
                                  <Children>
                                    <Widget DoNotAcceptEvents="true" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Sprite="BlankWhiteSquare_9" Color="#FFFFFFFF" AlphaFactor="0.10" IsVisible="@IsSelected" />
                                    <Widget DoNotAcceptEvents="true" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="54" SuggestedHeight="54" HorizontalAlignment="Left" VerticalAlignment="Center" MarginLeft="6" CircularClipEnabled="true" CircularClipRadius="27">
                                      <Children>
                                        <ImageIdentifierWidget DataSource="{Visual}" DoNotAcceptEvents="true" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" AdditionalArgs="@AdditionalArgs" ImageId="@Id" TextureProviderName="@TextureProviderName" />
                                      </Children>
                                    </Widget>
                                    <ListPanel DoNotAcceptEvents="true" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" MarginLeft="72" MarginRight="30" StackLayout.LayoutMethod="VerticalTopToBottom">
                                      <Children>
                                        <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" StackLayout.LayoutMethod="HorizontalLeftToRight">
                                          <Children>
                                            <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" Brush="Popup.Description.Text" Brush.TextHorizontalAlignment="Left" Text="@Name" />
                                            <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" MarginLeft="8" Brush="Popup.Description.Text" Brush.FontSize="14" Brush.FontColor="@PresenceColor" Brush.TextHorizontalAlignment="Left" Text="@PresenceText" />
                                          </Children>
                                        </ListPanel>
                                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" Brush="Popup.Description.Text" Brush.FontSize="15" Brush.FontColor="#8E8A80FF" Brush.TextHorizontalAlignment="Left" Text="@Detail" />
                                      </Children>
                                    </ListPanel>
                                    <TextWidget DoNotAcceptEvents="true" WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" HorizontalAlignment="Right" VerticalAlignment="Center" MarginRight="12" Brush="Popup.Description.Text" Brush.FontColor="#E3B54AFF" Text="●" IsVisible="@HasUnread" />
                                  </Children>
                                </ButtonWidget>
                              </ItemTemplate>
                            </ListPanel>
                          </Children>
                        </Widget>
                      </Children>
                    </ScrollablePanel>

                    <ScrollbarWidget Id="ContactsScrollbar" WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="8" HorizontalAlignment="Right" VerticalAlignment="Center" AlignmentAxis="Vertical" Handle="ContactsScrollbarHandle" MinValue="0" MaxValue="100">
                      <Children>
                        <BrushWidget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="2" HorizontalAlignment="Center" Brush="Encyclopedia.Scrollbar.Flat.Bed" />
                        <BrushWidget Id="ContactsScrollbarHandle" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="6" SuggestedHeight="50" HorizontalAlignment="Center" Brush="Encyclopedia.Scrollbar.Flat.Handle" />
                      </Children>
                    </ScrollbarWidget>

                  </Children>
                </Widget>

              </Children>
            </Widget>

            <!-- column divider -->
            <Widget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="2" HorizontalAlignment="Left" MarginLeft="362" MarginTop="24" MarginBottom="24" Sprite="BlankWhiteSquare_9" Color="#FFFFFFFF" AlphaFactor="0.12" />

            <!-- ============================ right: the shared story ============================ -->
            <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" MarginLeft="380" MarginRight="20" MarginTop="18" MarginBottom="18">
              <Children>

                <!-- before anyone is chosen -->
                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush="Popup.Description.Text" Brush.FontColor="#9AA3B2FF" Brush.TextHorizontalAlignment="Center" Text="@EmptyHint" IsHidden="@HasSelection" />

                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" IsVisible="@HasSelection">
                  <Children>

                    <!-- header: their name, how their heart stands toward you, and the deep-memory toggle -->
                    <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="40" VerticalAlignment="Top" MarginRight="240" StackLayout.LayoutMethod="HorizontalLeftToRight">
                      <Children>
                        <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="StretchToParent" VerticalAlignment="Center" Brush="Popup.Title.Text" Brush.TextHorizontalAlignment="Left" Text="@SelectedName" />
                        <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="StretchToParent" VerticalAlignment="Center" MarginLeft="16" Brush="Popup.Description.Text" Brush.FontSize="16" Brush.FontColor="@RelationColor" Brush.TextHorizontalAlignment="Left" Text="@RelationText" IsVisible="@HasRelation" />
                      </Children>
                    </ListPanel>
                    <ButtonWidget DoNotPassEventsToChildren="true" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="200" SuggestedHeight="40" HorizontalAlignment="Right" VerticalAlignment="Top" MarginRight="44" Brush="Popup.Cancel.Button" Command.Click="ExecuteToggleOverview" IsVisible="@HasOverview">
                      <Children>
                        <TextWidget DoNotAcceptEvents="true" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush="Popup.Button.Text" Brush.FontSize="18" Brush.TextHorizontalAlignment="Center" Text="@OverviewToggleText" />
                      </Children>
                    </ButtonWidget>

                    <!-- the deep-memory overview: what lingers of you beyond the thread -->
                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="176" VerticalAlignment="Top" MarginTop="50" IsVisible="@ShowOverviewBlock">
                      <Children>
                        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Sprite="BlankWhiteSquare_9" Color="#FFFFFFFF" AlphaFactor="0.05" />
                        <ScrollablePanel Id="OverviewScroller" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" MarginLeft="10" MarginRight="18" MarginTop="8" MarginBottom="8" ClipRect="OverviewClip" InnerPanel="OverviewClip\OverviewBody" VerticalScrollbar="..\OverviewScrollbar" MouseScrollAxis="Vertical" AutoHideScrollBars="true">
                          <Children>
                            <Widget Id="OverviewClip" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" ClipContents="true">
                              <Children>
                                <RichTextWidget Id="OverviewBody" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Top" Brush="Popup.Description.Text" Brush.FontSize="18" Brush.FontColor="#C9BFA8FF" Text="@OverviewText" />
                              </Children>
                            </Widget>
                          </Children>
                        </ScrollablePanel>
                        <ScrollbarWidget Id="OverviewScrollbar" WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="8" HorizontalAlignment="Right" VerticalAlignment="Center" MarginTop="8" MarginBottom="8" MarginRight="4" AlignmentAxis="Vertical" Handle="OverviewScrollbarHandle" MinValue="0" MaxValue="100">
                          <Children>
                            <BrushWidget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="2" HorizontalAlignment="Center" Brush="Encyclopedia.Scrollbar.Flat.Bed" />
                            <BrushWidget Id="OverviewScrollbarHandle" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="6" SuggestedHeight="40" HorizontalAlignment="Center" Brush="Encyclopedia.Scrollbar.Flat.Handle" />
                          </Children>
                        </ScrollbarWidget>
                      </Children>
                    </Widget>

                    <!-- the thread -->
                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" MarginTop="@MessagesTopMargin" MarginBottom="@MessagesBottomMargin">
                      <Children>
                        <ScrollablePanel Id="MessagesScroller" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" ClipRect="MessagesClip" InnerPanel="MessagesClip\MessagesList" VerticalScrollbar="..\MessagesScrollbar" MouseScrollAxis="Vertical" AutoHideScrollBars="true">
                          <Children>
                            <Widget Id="MessagesClip" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" ClipContents="true">
                              <Children>
                                <ListPanel Id="MessagesList" DataSource="{Messages}" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Bottom" StackLayout.LayoutMethod="VerticalTopToBottom">
                                  <ItemTemplate>
                                    <ListPanel DoNotAcceptEvents="true" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginBottom="12" MarginRight="16" StackLayout.LayoutMethod="VerticalTopToBottom">
                                      <Children>
                                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" Brush="Popup.Description.Text" Brush.FontSize="15" Brush.FontColor="@HeaderColor" Brush.TextHorizontalAlignment="Left" Text="@Header" IsVisible="@HasHeader" />
                                        <RichTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginLeft="10" Brush="Popup.Description.Text" Brush.FontSize="19" Text="@Body" IsHidden="@IsNarration" />
                                        <RichTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" MarginLeft="10" Brush="Popup.Description.Text" Brush.FontSize="16" Brush.FontColor="#9AA3B2FF" Text="@Body" IsVisible="@IsNarration" />
                                      </Children>
                                    </ListPanel>
                                  </ItemTemplate>
                                </ListPanel>
                              </Children>
                            </Widget>
                          </Children>
                        </ScrollablePanel>
                        <ScrollbarWidget Id="MessagesScrollbar" WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="8" HorizontalAlignment="Right" VerticalAlignment="Center" AlignmentAxis="Vertical" Handle="MessagesScrollbarHandle" MinValue="0" MaxValue="100">
                          <Children>
                            <BrushWidget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="2" HorizontalAlignment="Center" Brush="Encyclopedia.Scrollbar.Flat.Bed" />
                            <BrushWidget Id="MessagesScrollbarHandle" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="6" SuggestedHeight="50" HorizontalAlignment="Center" Brush="Encyclopedia.Scrollbar.Flat.Handle" />
                          </Children>
                        </ScrollbarWidget>
                      </Children>
                    </Widget>

                    <!-- the whole of what you are typing, wrapped — the single-line input below can
                         only show its tail, so the draft mirror is where a long message stays
                         readable while it is written (newest lines pinned to the bottom) -->
                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="84" VerticalAlignment="Bottom" MarginBottom="78" MarginRight="210" IsVisible="@HasDraft">
                      <Children>
                        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Sprite="BlankWhiteSquare_9" Color="#FFFFFFFF" AlphaFactor="0.05" />
                        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" MarginLeft="10" MarginRight="10" MarginTop="6" MarginBottom="6" ClipContents="true">
                          <Children>
                            <RichTextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Bottom" Brush="Popup.Description.Text" Brush.FontSize="17" Brush.FontColor="#D9C08CFF" Text="@InputText" />
                          </Children>
                        </Widget>
                      </Children>
                    </Widget>

                    <!-- when the chosen one is away across the map, a gentle note that words cannot reach
                         them now — the send stays grayed; a letter is the road (see AwayNotice) -->
                    <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Bottom" MarginBottom="86" MarginRight="210" Brush="Popup.Description.Text" Brush.FontSize="16" Brush.FontColor="#B9A98BFF" Brush.TextHorizontalAlignment="Center" Text="@AwayNotice" IsVisible="@IsAway" />

                    <!-- your words -->
                    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="70" VerticalAlignment="Bottom" MarginRight="210" Sprite="General\CharacterCreation\name_input_area">
                      <Children>
                        <EditableTextWidget Id="ChatInput" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" VerticalAlignment="Center" MarginLeft="14" MarginRight="14" MarginTop="12" MarginBottom="12" Brush="Review.NameInput.Text" Brush.FontSize="18" Brush.TextHorizontalAlignment="Left" RealText="@InputText" MaxLength="1000" />
                      </Children>
                    </Widget>
                    <ButtonWidget DoNotPassEventsToChildren="true" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="190" SuggestedHeight="62" HorizontalAlignment="Right" VerticalAlignment="Bottom" MarginBottom="4" Brush="Popup.Done.Button" Command.Click="ExecuteSend" IsEnabled="@CanSend">
                      <Children>
                        <TextWidget DoNotAcceptEvents="true" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush="Popup.Button.Text" Brush.TextHorizontalAlignment="Center" Text="@SendText" />
                      </Children>
                    </ButtonWidget>

                  </Children>
                </Widget>

              </Children>
            </Widget>

            <!-- close -->
            <ButtonWidget DoNotPassEventsToChildren="true" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="34" SuggestedHeight="34" HorizontalAlignment="Right" VerticalAlignment="Top" MarginTop="8" MarginRight="8" Command.Click="ExecuteClose">
              <Children>
                <TextWidget DoNotAcceptEvents="true" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" VerticalAlignment="Center" Brush="Popup.Description.Text" Brush.TextHorizontalAlignment="Center" Text="X" />
              </Children>
            </ButtonWidget>

            <!-- frame border -->
            <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Sprite="frame_9" ExtendLeft="18" ExtendTop="18" ExtendRight="18" ExtendBottom="18" IsEnabled="false" />

          </Children>
        </Widget>

      </Children>
    </Widget>
  </Window>
</Prefab>
